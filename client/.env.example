# CDP Communication Hub - Frontend Environment
# Copy to .env.local and fill in your values

# Backend API URL (Render URL in production, localhost in dev)
NEXT_PUBLIC_API_URL=http://localhost:3001

# Frontend app URL (used for metadata/Open Graph absolute URLs)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Web Push (VAPID public key — same value as VAPID_PUBLIC_KEY on the server)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=your-vapid-public-key
