# ═══════════════════════════════════════════════════════════════
# CDP Communication Hub — Environment Variables
# Copy to .env and fill in your values before starting
# ═══════════════════════════════════════════════════════════════

# ═══ DATABASE (Supabase) ═══════════════════════════════════════
# Pooled connection (port 6543) — used by the app at runtime
DATABASE_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:6543/postgres?pgbouncer=true"
# Direct connection (port 5432) — used by Prisma for migrations
DIRECT_URL="postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-eu-west-1.pooler.supabase.com:5432/postgres"

# ═══ REQUIRED ═══════════════════════════════════════════════════

JWT_SECRET=replace-with-at-least-32-char-secret-string
JWT_EXPIRES_IN=7d
ENCRYPTION_KEY=replace-with-at-least-32-char-encryption-key

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3001/auth/google/callback

FRONTEND_URL=http://localhost:3000

# ═══ SERVER ═════════════════════════════════════════════════════

PORT=3001
HOST=0.0.0.0
NODE_ENV=development

# ═══ AI PROVIDERS (at least one required) ════════════════════════

GROQ_API_KEY=gsk_your-groq-api-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-api-key
OPENAI_API_KEY=sk-your-openai-api-key
AI_PROVIDER=groq

# ═══ PUSH NOTIFICATIONS (optional) ══════════════════════════════
# Generate VAPID keys with: cd server && npm run generate-vapid

VAPID_PUBLIC_KEY=your-vapid-public-key
VAPID_PRIVATE_KEY=your-vapid-private-key
VAPID_SUBJECT=mailto:your-email@example.com

# ═══ AGENT / SIRI API (optional) ═════════════════════════════════
# Used by Apple Shortcuts and COMMAND_API_KEY-authenticated integrations

COMMAND_API_KEY=your-command-api-key

# ═══ VERCEL CRON (required for serverless deployment) ═══════════
CRON_SECRET=replace-with-cron-secret

# ═══ SECURITY ════════════════════════════════════════════════════

CSRF_SECRET=replace-with-csrf-secret
