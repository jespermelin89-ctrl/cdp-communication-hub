{
  "name": "cdp-communication-hub-server",
  "version": "1.0.0",
  "description": "CDP Communication Hub - AI-powered email overlay backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && (prisma db push --accept-data-loss || echo 'DB push skipped') && tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@prisma/client": "^6.2.0",
    "fastify": "^5.2.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/rate-limit": "^10.2.0",
    "googleapis": "^144.0.0",
    "jsonwebtoken": "^9.0.2",
    "zod": "^3.24.0",
    "dotenv": "^16.4.0",
    "openai": "^4.77.0",
    "imapflow": "^1.0.170",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.9.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/nodemailer": "^6.4.17",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
