{
  "name": "cdp-communication-hub-server",
  "version": "1.1.0",
  "description": "CDP Communication Hub - AI-powered email overlay backend",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && (prisma migrate resolve --applied 0_init 2>/dev/null || true) && prisma migrate deploy && tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "seed:brain-core": "tsx src/scripts/seed-brain-core.ts",
    "generate-vapid": "tsx src/scripts/generate-vapid.ts",
    "lint": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fastify/cookie": "^11.0.0",
    "@fastify/cors": "^10.0.0",
    "@fastify/helmet": "^13.0.2",
    "@fastify/multipart": "^9.4.0",
    "@fastify/rate-limit": "^10.2.0",
    "@prisma/client": "^6.2.0",
    "dotenv": "^16.4.0",
    "fastify": "^5.2.0",
    "googleapis": "^144.0.0",
    "imapflow": "^1.0.170",
    "jsonwebtoken": "^9.0.2",
    "mailparser": "^3.7.0",
    "nodemailer": "^6.9.0",
    "openai": "^4.77.0",
    "web-push": "^3.6.7",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/jsonwebtoken": "^9.0.7",
    "@types/node": "^22.10.0",
    "@types/nodemailer": "^6.4.17",
    "@types/web-push": "^3.6.4",
    "@vitest/coverage-v8": "^3.2.4",
    "pino-pretty": "^13.1.3",
    "prisma": "^6.2.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  },
  "prisma": {
    "schema": "src/prisma/schema.prisma"
  }
}
